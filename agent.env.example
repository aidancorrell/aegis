# Mako agent env — copy to agent.env and fill in values
# Real API keys are held by ClawShield. Mako gets dummy keys intercepted by the proxy.

MAKO_ANTHROPIC_API_KEY=DUMMY_KEY_INTERCEPTED_BY_CLAWSHIELD
MAKO_GEMINI_API_KEY=DUMMY_KEY_INTERCEPTED_BY_CLAWSHIELD
MAKO_DEFAULT_PROVIDER=claude

# Routes Mako's Anthropic SDK through ClawShield proxy (no DNS tricks needed)
ANTHROPIC_BASE_URL=http://clawshield:8000/proxy/anthropic

# Optional: Telegram channel
# MAKO_TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# MAKO_TELEGRAM_ALLOWED_CHAT_IDS_STR=your_chat_id

# Optional: Discord channel
# MAKO_DISCORD_BOT_TOKEN=your_discord_bot_token
# MAKO_DISCORD_ALLOWED_USER_IDS_STR=your_discord_user_id
