# ClawShield environment — copy to clawshield.env and fill in values

# Real API keys (ClawShield holds these, agents get dummy keys via proxy)
CLAWSHIELD_REAL_GEMINI_API_KEY=
CLAWSHIELD_REAL_ANTHROPIC_API_KEY=
CLAWSHIELD_REAL_OPENAI_API_KEY=

# Security behavior
CLAWSHIELD_BLOCK_INJECTIONS=false

# Mode: builtin (use engine.py) or proxy (wrap external agent)
CLAWSHIELD_MODE=builtin

# Audit log path (shared volume from agent container, Mode A only)
# CLAWSHIELD_AUDIT_LOG_PATH=/mnt/agent-audit/audit.log
