# ClawShield environment — copy to clawshield.env and fill in your real API key
# These keys are held only by ClawShield. The agent container never sees them.

# Set the key for whichever provider Mako is configured to use
CLAWSHIELD_REAL_ANTHROPIC_API_KEY=
CLAWSHIELD_REAL_GEMINI_API_KEY=
CLAWSHIELD_REAL_OPENAI_API_KEY=

# Block detected injections before they reach the LLM (recommended: true)
CLAWSHIELD_BLOCK_INJECTIONS=true

# Path to Mako's audit log (mounted as shared read-only volume)
CLAWSHIELD_AUDIT_LOG_PATH=/mnt/agent-audit/audit.log
